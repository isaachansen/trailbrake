{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Trailbrake",
  "version": "0.2.0",
  "identifier": "com.simoverlay.dev",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1421",
    "beforeDevCommand": "npm run dev:tauri",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "manager",
        "title": "Trailbrake",
        "width": 1180,
        "height": 760,
        "minWidth": 940,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "visible": false,
        "focus": false
      },
      {
        "label": "overlay",
        "title": "sim-overlay-canvas",
        "width": 1280,
        "height": 800,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "shadow": false,
        "resizable": false,
        "fullscreen": false,
        "skipTaskbar": true,
        "visible": false,
        "focus": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/isaachansen/trailbrake/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIyNTExOEFCMzE4RTVCMDQKUldRRVc0NHhxeGhSc2pYQUk3eXNnVFBYbVFMOW45Z2xxVHRtU2Fibm1MWS9odktIN0QvRm5lR24K"
    }
  }
}
